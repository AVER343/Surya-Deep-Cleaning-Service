---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Testimonials from "../components/Testimonials.astro";
import Section from "../components/ui/Section.astro";
import { ArrowRight } from "lucide-react";
---

<Layout
    title="Customer Reviews | Home Cleaning & Co St. Petersburg, FL"
    description="Read real feedback from homeowners and hosts who use Home Cleaning & Co for recurring, deep, move-out, and turnover cleaning."
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify([
                {
                    "@context": "https://schema.org",
                    "@type": "LocalBusiness",
                    name: "Home Cleaning & Co",
                    url: "https://homecleaningco.com",
                    aggregateRating: {
                        "@type": "AggregateRating",
                        ratingValue: "5.0",
                        reviewCount: "9",
                        bestRating: "5",
                    },
                },
                {
                    "@context": "https://schema.org",
                    "@type": "BreadcrumbList",
                    itemListElement: [
                        {
                            "@type": "ListItem",
                            position: 1,
                            name: "Home",
                            item: "https://homecleaningco.com/",
                        },
                        {
                            "@type": "ListItem",
                            position: 2,
                            name: "Reviews",
                            item: "https://homecleaningco.com/reviews",
                        },
                    ],
                },
            ])}
        />
    </Fragment>

    <Header />

    <main>
        <Section class="bg-background-mint pt-36 pb-8 md:pt-40">
            <div class="max-w-3xl mx-auto text-center">
                <span
                    class="inline-flex items-center gap-1.5 text-text-600 font-semibold tracking-wider uppercase text-xs bg-white border border-border-light px-4 py-1.5 rounded-full mb-4"
                    >Client Feedback</span
                >
                <h1
                    class="text-4xl md:text-5xl font-bold text-secondary mb-6 tracking-tight"
                >
                    Trusted by Homeowners Across St. Petersburg
                </h1>
                <p class="text-text-600 text-lg leading-relaxed">
                    See what clients say about our quality, consistency, and
                    responsiveness after each visit.
                </p>
            </div>
        </Section>

        <Testimonials variant="full" showHeader={false} />

        <Section class="bg-background-mint py-4 md:py-12">
            <div class="text-center">
                <a
                    href="/book"
                    class="inline-flex items-center gap-2 bg-primary text-white font-bold px-8 py-3.5 rounded-full shadow-lg shadow-primary/30 hover:bg-primary-dark hover:-translate-y-0.5 transition-all duration-300"
                >
                    Book Your Cleaning
                    <ArrowRight className="w-5 h-5" />
                </a>
            </div>
        </Section>
    </main>

    <Footer />
</Layout>
