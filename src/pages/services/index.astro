---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Section from "../../components/ui/Section.astro";
import { SERVICE_CONTENT } from "../../content/services";
import { ArrowRight, CheckCircle2, Star } from "lucide-react";
import BOOKING_CATALOG from "../../generated/booking-catalog";
import {
    formatUsd,
    getAvailableCitiesForService,
    getStartingPriceForService,
} from "../../lib/catalog";

const featuredService = SERVICE_CONTENT[0];
const remainingServices = SERVICE_CONTENT.slice(1);
const featuredServiceHref = `/services/${featuredService.slug}`;
const featuredBookHref = `/book?service=${featuredService.slug}`;
const featuredStartingPrice = getStartingPriceForService(
    featuredService.id,
    undefined,
    BOOKING_CATALOG,
);
const featuredCityPages = getAvailableCitiesForService(
    featuredService.slug,
    BOOKING_CATALOG,
).slice(0, 4);
---

<Layout
    title="Cleaning Services in St. Petersburg, FL | Home Cleaning & Co"
    description="Browse residential and office cleaning services in St. Petersburg, including deep cleaning, recurring maintenance, move-in/out, Airbnb, and post-construction cleaning."
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify([
                {
                    "@context": "https://schema.org",
                    "@type": "OfferCatalog",
                    name: "Cleaning Services",
                    itemListElement: SERVICE_CONTENT.map((service) => ({
                        "@type": "Offer",
                        itemOffered: {
                            "@type": "Service",
                            name: service.name,
                            description: service.shortDescription,
                            url: `https://homecleaningco.com/services/${service.slug}`,
                        },
                    })),
                },
                {
                    "@context": "https://schema.org",
                    "@type": "BreadcrumbList",
                    itemListElement: [
                        {
                            "@type": "ListItem",
                            position: 1,
                            name: "Home",
                            item: "https://homecleaningco.com/",
                        },
                        {
                            "@type": "ListItem",
                            position: 2,
                            name: "Services",
                            item: "https://homecleaningco.com/services",
                        },
                    ],
                },
            ])}
        />
    </Fragment>

    <Header />

    <main>
        <Section
            class="relative overflow-hidden bg-background-mint pt-36 pb-20 md:pt-40 md:pb-24"
        >
            <div class="absolute inset-0 pointer-events-none">
                <div
                    class="absolute -top-16 right-[10%] h-64 w-64 rounded-full bg-primary/8 blur-3xl"
                >
                </div>
                <div
                    class="absolute bottom-0 left-[5%] h-56 w-56 rounded-full bg-secondary/5 blur-3xl"
                >
                </div>
            </div>

            <div class="relative z-10 max-w-[1180px] mx-auto">
                <div class="max-w-3xl mx-auto text-center mb-12 md:mb-16">
                    <span
                        class="inline-flex items-center gap-1.5 text-text-600 font-semibold tracking-[0.2em] uppercase text-xs bg-white border border-border-light px-4 py-1.5 rounded-full mb-4"
                        >Our Services</span
                    >
                    <h1 class="h1-tier-2 font-bold text-secondary mb-5">
                        Cleaning Solutions for Every Home and Schedule
                    </h1>
                    <p
                        class="max-w-2xl mx-auto text-text-600 text-lg leading-relaxed"
                    >
                        Explore our most requested cleaning services, compare
                        what each visit includes, and move directly into booking
                        when you are ready.
                    </p>
                </div>

                <article
                    class="relative overflow-hidden rounded-[2rem] border border-border-light bg-white p-6 md:p-8 lg:p-10 shadow-[0_24px_80px_rgba(12,12,12,0.08)] mb-14 md:mb-20"
                >
                    <div
                        class="absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-primary/5 to-transparent pointer-events-none"
                    >
                    </div>

                    <div
                        class="relative grid md:grid-cols-2 lg:grid-cols-[0.95fr_1.05fr] gap-8 lg:gap-12 items-center"
                    >
                        <div class="animate-fade-in-up">
                            <div class="flex flex-wrap items-center gap-3 mb-5">
                                <span
                                    class="inline-flex items-center rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-[0.2em] px-4 py-1.5"
                                >
                                    Featured Service
                                </span>
                                <span
                                    class="inline-flex items-center rounded-full bg-surface text-text-600 text-xs font-semibold uppercase tracking-[0.15em] px-4 py-1.5 border border-border-light"
                                >
                                    {featuredService.hero.eyebrow}
                                </span>
                            </div>

                            <h2
                                class="text-3xl md:text-4xl lg:text-5xl font-bold text-secondary tracking-tight leading-[1.04] mb-4"
                            >
                                {featuredService.hero.headline}
                            </h2>
                            <p
                                class="text-text-600 text-lg leading-relaxed mb-8 max-w-xl"
                            >
                                {featuredService.shortDescription} Start with our
                                most-booked option and compare the rest of the catalog
                                below.
                            </p>

                            <div
                                class="rounded-3xl border border-border-light bg-background-mint px-5 py-4 mb-8"
                            >
                                <p
                                    class="text-xs font-bold uppercase tracking-[0.18em] text-text-500 mb-2"
                                >
                                    Starting At
                                </p>
                                <p
                                    class="text-3xl font-bold text-secondary mb-2"
                                >
                                    {formatUsd(featuredStartingPrice)}
                                </p>
                                <p
                                    class="text-sm text-text-600 leading-relaxed"
                                >
                                    {featuredService.pricingNote}
                                </p>
                            </div>

                            <ul class="grid sm:grid-cols-2 gap-3 mb-8">
                                {
                                    featuredService.heroHighlights.map(
                                        (highlight) => (
                                            <li class="flex items-center gap-3 rounded-2xl border border-border-light bg-background-mint px-4 py-3 text-sm font-medium text-secondary">
                                                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10 text-primary shrink-0">
                                                    <CheckCircle2 className="w-4 h-4" />
                                                </span>
                                                <span>{highlight}</span>
                                            </li>
                                        ),
                                    )
                                }
                            </ul>

                            <div class="flex flex-wrap gap-3">
                                <a
                                    href={featuredServiceHref}
                                    class="inline-flex items-center gap-2 bg-primary text-white font-bold px-8 py-3.5 rounded-full shadow-lg shadow-primary/30 hover:bg-primary-dark hover:-translate-y-0.5 transition-all duration-300"
                                >
                                    View Service
                                    <ArrowRight className="w-5 h-5" />
                                </a>
                                <a
                                    href={featuredBookHref}
                                    class="inline-flex items-center gap-2 bg-white text-secondary font-semibold px-6 py-3.5 rounded-full border border-border-light hover:bg-surface transition-colors"
                                >
                                    Book Now
                                </a>
                            </div>
                        </div>

                        <a
                            href={featuredServiceHref}
                            class="service-feature-card group animate-fade-in-up delay-100"
                        >
                            <div
                                class="relative overflow-hidden rounded-[1.75rem] shadow-2xl"
                            >
                                {
                                    featuredService.badge && (
                                        <span class="absolute top-5 right-5 z-10 inline-flex items-center gap-1.5 rounded-full bg-primary px-4 py-2 text-[11px] font-bold uppercase tracking-[0.18em] text-white shadow-lg">
                                            <Star className="w-3.5 h-3.5 fill-current" />
                                            {featuredService.badge}
                                        </span>
                                    )
                                }
                                <img
                                    src={featuredService.image}
                                    alt={featuredService.name}
                                    class="w-full aspect-[5/4] object-cover"
                                    loading="eager"
                                />
                                <div
                                    class="service-feature-image-overlay absolute inset-0 bg-gradient-to-t from-secondary/55 via-secondary/5 to-transparent"
                                >
                                </div>
                                <div
                                    class="absolute left-6 right-6 bottom-6 flex items-end justify-between gap-4"
                                >
                                    <div>
                                        <p
                                            class="text-white text-2xl font-bold tracking-tight"
                                        >
                                            {featuredService.name}
                                        </p>
                                        <p class="text-white/80 text-sm mt-1">
                                            Starting at {
                                                formatUsd(featuredStartingPrice)
                                            }
                                        </p>
                                    </div>
                                    <span
                                        class="service-feature-cta inline-flex items-center gap-2 rounded-full bg-white/95 px-4 py-2 text-sm font-semibold text-secondary"
                                    >
                                        Explore
                                        <ArrowRight className="w-4 h-4" />
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                </article>

                <div
                    class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-8"
                >
                    <div class="max-w-xl">
                        <span
                            class="inline-flex items-center rounded-full bg-white border border-border-light text-text-600 text-xs font-semibold uppercase tracking-[0.2em] px-4 py-1.5 mb-3"
                        >
                            Full Catalog
                        </span>
                        <h2
                            class="text-3xl md:text-4xl font-bold text-secondary tracking-tight"
                        >
                            Browse Every Cleaning Service
                        </h2>
                    </div>
                    <a
                        href="/book"
                        class="inline-flex items-center justify-center gap-2 bg-primary text-white font-semibold px-6 py-3 rounded-full hover:bg-primary-dark transition-colors self-start md:self-auto shrink-0"
                    >
                        Book a Visit
                        <ArrowRight className="w-4 h-4 shrink-0" />
                    </a>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-sm md:max-w-none mx-auto w-full"
                >
                    {
                        remainingServices.map((service) => (
                            <article class="group relative rounded-[1.75rem] overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-border-light">
                                <a
                                    href={`/services/${service.slug}`}
                                    class="block"
                                >
                                    <div class="relative h-80 overflow-hidden">
                                        {service.badge && (
                                            <span class="absolute top-4 left-4 z-20 inline-flex items-center gap-1.5 rounded-full bg-primary px-3 py-1.5 text-[11px] font-bold uppercase tracking-[0.12em] text-white shadow-lg">
                                                <Star className="w-3 h-3 fill-current shrink-0" />
                                                {service.badge}
                                            </span>
                                        )}
                                        <img
                                            src={service.image}
                                            alt={service.name}
                                            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                                            loading="lazy"
                                        />
                                        {/* Permanent bottom gradient — always shows name + price */}
                                        <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 via-secondary/20 to-transparent transition-opacity duration-300 group-hover:opacity-0" />
                                        <div class="absolute left-5 right-5 bottom-5 flex items-end justify-between gap-3 z-10 transition-opacity duration-300 group-hover:opacity-0">
                                            <h3 class="text-lg font-bold text-white tracking-tight leading-snug">
                                                {service.name}
                                            </h3>
                                            <span class="shrink-0 text-xs font-semibold text-white/75">
                                                From{" "}
                                                {formatUsd(
                                                    getStartingPriceForService(
                                                        service.id,
                                                        undefined,
                                                        BOOKING_CATALOG,
                                                    ),
                                                )}
                                            </span>
                                        </div>
                                        {/* Hover overlay — description + CTA */}
                                        <div class="absolute inset-0 bg-secondary/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6">
                                            <p class="text-white/90 text-sm leading-relaxed mb-4 translate-y-3 group-hover:translate-y-0 transition-transform duration-300">
                                                {service.shortDescription}
                                            </p>
                                            <span class="inline-flex items-center gap-2 self-start bg-primary text-white font-bold text-sm px-5 py-2.5 rounded-full translate-y-3 group-hover:translate-y-0 transition-transform duration-300 delay-75">
                                                View Service
                                                <ArrowRight className="w-4 h-4" />
                                            </span>
                                        </div>
                                    </div>
                                </a>
                            </article>
                        ))
                    }
                </div>

                <div
                    class="mt-10 rounded-[1.75rem] border border-border-light bg-white p-5 md:p-6 shadow-sm"
                >
                    <div
                        class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4"
                    >
                        <div>
                            <p
                                class="text-xs font-bold uppercase tracking-[0.18em] text-text-500 mb-2"
                            >
                                Local Landing Pages
                            </p>
                            <h2
                                class="text-2xl md:text-3xl font-bold text-secondary"
                            >
                                Explore services by city and service area
                            </h2>
                        </div>
                        <a
                            href="/locations"
                            class="inline-flex items-center gap-2 text-primary font-semibold"
                        >
                            View all locations
                            <ArrowRight className="w-4 h-4" />
                        </a>
                    </div>
                    <div class="flex flex-wrap gap-2 mt-5">
                        {
                            featuredCityPages.map(({ location }) => (
                                <a
                                    href={`/services/${featuredService.slug}/${location.slug}`}
                                    class="inline-flex items-center rounded-full bg-background-mint border border-border-light px-3 py-2 text-sm font-medium text-text-600 hover:border-primary/30 hover:text-primary transition-colors"
                                >
                                    {featuredService.name} in {location.name}
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>
        </Section>
    </main>

    <style>
        @media (hover: hover) and (pointer: fine) {
            .service-catalog-card .service-catalog-image-overlay,
            .service-feature-card .service-feature-image-overlay,
            .service-catalog-card .service-catalog-hover-copy,
            .service-feature-card .service-feature-cta {
                transition:
                    opacity 220ms ease,
                    transform 220ms ease,
                    background 220ms ease,
                    box-shadow 220ms ease,
                    color 220ms ease;
            }

            .service-catalog-card:hover .service-catalog-image-overlay {
                background: linear-gradient(
                    to top,
                    rgba(12, 12, 12, 0.78),
                    rgba(12, 12, 12, 0.22),
                    rgba(12, 12, 12, 0)
                );
            }

            .service-catalog-card:hover .service-catalog-hover-copy {
                opacity: 1;
                transform: translateY(0);
            }

            .service-feature-card:hover .service-feature-image-overlay {
                background: linear-gradient(
                    to top,
                    rgba(12, 12, 12, 0.72),
                    rgba(12, 12, 12, 0.18),
                    rgba(12, 12, 12, 0)
                );
            }

            .service-feature-card:hover .service-feature-cta {
                background: rgb(5 150 105);
                color: white;
                box-shadow: 0 16px 40px rgba(5, 150, 105, 0.25);
            }
        }
    </style>

    <Footer />
</Layout>
