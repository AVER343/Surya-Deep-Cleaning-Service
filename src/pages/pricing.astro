---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Section from "../components/ui/Section.astro";
import BOOKING_CATALOG from "../generated/booking-catalog";
import { getServiceById } from "../content/services";
import { formatUsd } from "../lib/catalog";
import { ArrowRight } from "lucide-react";

const pricingCards = BOOKING_CATALOG.services
    .map((catalogService) => {
        const service = getServiceById(catalogService.id);
        if (!service) return undefined;
        return {
            service,
            startingPrice: catalogService.globalStartingPrice,
        };
    })
    .filter((entry): entry is { service: NonNullable<ReturnType<typeof getServiceById>>; startingPrice: number } => Boolean(entry));
---

<Layout
    title="House Cleaning Pricing | Home Cleaning & Co"
    description="See starting prices for our house cleaning services and understand what affects the final quote for your home."
>
    <Fragment slot="head">
        <script
            type="application/ld+json"
            set:html={JSON.stringify([
                {
                    "@context": "https://schema.org",
                    "@type": "OfferCatalog",
                    name: "House Cleaning Pricing",
                    itemListElement: pricingCards.map(({ service, startingPrice }) => ({
                        "@type": "Offer",
                        name: service.name,
                        priceCurrency: "USD",
                        price: startingPrice,
                        description: service.pricingNote,
                    })),
                },
                {
                    "@context": "https://schema.org",
                    "@type": "BreadcrumbList",
                    itemListElement: [
                        {
                            "@type": "ListItem",
                            position: 1,
                            name: "Home",
                            item: "https://homecleaningco.com/",
                        },
                        {
                            "@type": "ListItem",
                            position: 2,
                            name: "Pricing",
                            item: "https://homecleaningco.com/pricing",
                        },
                    ],
                },
            ])}
        />
    </Fragment>

    <Header />

    <main>
        <Section class="bg-background-mint pt-36 pb-20 md:pt-40 md:pb-24">
            <div class="max-w-3xl mx-auto text-center">
                <span class="inline-flex items-center gap-1.5 text-text-600 font-semibold tracking-[0.2em] uppercase text-xs bg-white border border-border-light px-4 py-1.5 rounded-full mb-4">
                    Pricing
                </span>
                <h1 class="h1-tier-2 font-bold text-secondary mb-6">
                    Transparent Starting Prices for Every Cleaning Service
                </h1>
                <p class="text-text-600 text-lg leading-relaxed max-w-2xl mx-auto">
                    Use these starting prices as planning anchors, then tailor the service to your home size, service frequency, and any add-ons you need.
                </p>
            </div>
        </Section>

        <Section class="bg-white py-20 md:py-24">
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                {
                    pricingCards.map(({ service, startingPrice }) => (
                        <article class="rounded-[1.75rem] border border-border-light bg-background-mint p-6 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all h-full flex flex-col">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-text-500 mb-3">
                                {service.hero.eyebrow}
                            </p>
                            <h2 class="text-2xl font-bold text-secondary mb-2">
                                {service.name}
                            </h2>
                            <p class="text-3xl font-bold text-primary mb-4">
                                Starting at {formatUsd(startingPrice)}
                            </p>
                            <p class="text-text-600 leading-relaxed mb-6">
                                {service.pricingNote}
                            </p>
                            <a href={`/services/${service.slug}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary mt-auto">
                                View Service
                                <ArrowRight className="w-3.5 h-3.5" />
                            </a>
                        </article>
                    ))
                }
            </div>
        </Section>

        <Section class="bg-background-mint py-20 md:py-24">
            <div class="grid lg:grid-cols-3 gap-6">
                <div class="rounded-[1.75rem] border border-border-light bg-white p-6">
                    <h2 class="text-xl font-bold text-secondary mb-3">What affects price</h2>
                    <p class="text-text-600 leading-relaxed">Home size, bed and bath count, service frequency, and add-ons are the main inputs that shape the final estimate.</p>
                </div>
                <div class="rounded-[1.75rem] border border-border-light bg-white p-6">
                    <h2 class="text-xl font-bold text-secondary mb-3">Why prices vary</h2>
                    <p class="text-text-600 leading-relaxed">First-time resets, move-related jobs, and detail-heavy visits need more labor than routine maintenance cleaning.</p>
                </div>
                <div class="rounded-[1.75rem] border border-border-light bg-white p-6">
                    <h2 class="text-xl font-bold text-secondary mb-3">How to confirm your total</h2>
                    <p class="text-text-600 leading-relaxed">Choose your service, location, and home details in the booking flow to see the live estimate before you submit.</p>
                </div>
            </div>

            <div class="text-center mt-12">
                <a href="/book" class="inline-flex items-center gap-2 bg-primary text-white font-bold px-8 py-3.5 rounded-full shadow-lg shadow-primary/30 hover:bg-primary-dark hover:-translate-y-0.5 transition-all duration-300">
                    Start Booking
                    <ArrowRight className="w-5 h-5" />
                </a>
            </div>
        </Section>
    </main>

    <Footer />
</Layout>
