---
import Section from "./ui/Section.astro";
import { Star } from "lucide-react";
import { TESTIMONIALS } from "../content/testimonials";
import { HOMEPAGE_TEASERS } from "../content/homepage";

interface Props {
    variant?: "home" | "full";
    showHeader?: boolean;
}

const { variant = "home", showHeader = true } = Astro.props as Props;
const isHome = variant === "home";
const testimonials = isHome ? TESTIMONIALS.slice(0, 6) : TESTIMONIALS;
const sectionClass = showHeader
    ? "bg-background-mint py-16 md:py-24"
    : "bg-background-mint pt-4 pb-16 md:pt-8 md:pb-20";
---

<Section id="testimonials" class={sectionClass}>
    <div class="max-w-7xl mx-auto px-4">
        {showHeader && (
            <div class="text-center mb-14 px-4 animate-fade-in-up">
                <span
                    class="inline-flex items-center gap-1.5 text-text-600 font-semibold tracking-wider uppercase text-xs bg-surface border border-border-light px-4 py-1.5 rounded-full mb-4"
                    >Testimonials</span
                >
                <h2
                    class="text-4xl md:text-5xl font-bold text-secondary mb-6 font-sans tracking-tight"
                >
                    Loved by <span class="text-primary">Locals</span>
                </h2>
                <p class="text-text-light max-w-2xl mx-auto text-lg">
                    {
                        isHome
                            ? HOMEPAGE_TEASERS.reviews.description
                            : "Real client feedback from St. Petersburg and nearby communities."
                    }
                </p>
            </div>
        )}

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {
                testimonials.map((testimonial) => (
                    <article class="bg-white p-8 rounded-3xl shadow-sm border border-secondary/5 hover:shadow-md transition-shadow">
                        <div class="flex gap-1 mb-4 text-primary">
                            {[...Array(testimonial.rating)].map(() => (
                                <Star className="w-4 h-4 fill-current" />
                            ))}
                        </div>
                        <p class="text-text-600 mb-6 leading-relaxed">
                            "{testimonial.text}"
                        </p>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold">
                                {testimonial.name.charAt(0)}
                            </div>
                            <div>
                                <p class="font-bold text-sm text-secondary">
                                    {testimonial.name}
                                </p>
                                <p class="text-xs text-text-light">
                                    {testimonial.location}
                                </p>
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>

        {isHome && (
            <div class="text-center mt-12">
                <a
                    href={HOMEPAGE_TEASERS.reviews.href}
                    class="inline-flex items-center gap-2 bg-white text-secondary font-bold px-7 py-3 rounded-full border border-border-light hover:bg-surface transition-colors"
                >
                    {HOMEPAGE_TEASERS.reviews.cta}
                </a>
            </div>
        )}
    </div>
</Section>
