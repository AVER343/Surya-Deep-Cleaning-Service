---
import {
    Instagram,
    Facebook,
    Linkedin,
    Mail,
    Phone,
} from "lucide-react";
import { LOCATION_CONTENT } from "../content/locations";
import { SERVICE_CONTENT } from "../content/services";

const currentYear = new Date().getFullYear();
const supportLinks = [
    { label: "Reviews", href: "/reviews" },
    { label: "FAQ", href: "/faq" },
    { label: "Contact", href: "/contact" },
    { label: "Book Now", href: "/book" },
];
---

<footer class="bg-secondary text-white pt-20 pb-10">
    <div class="container mx-auto px-4 md:px-8">
        <div class="grid lg:grid-cols-[1.15fr_0.85fr_0.85fr_0.85fr] gap-10 mb-12">
            <div>
                <a href="/" class="inline-flex items-center gap-2 mb-5">
                    <img
                        src="/images/logo.png"
                        alt="Home Cleaning & Co"
                        class="h-12 w-auto object-contain brightness-0 invert"
                    />
                </a>
                <p class="text-white/65 text-base leading-relaxed max-w-md">
                    Licensed and insured home cleaning with clear pricing, reliable arrival windows, and flexible booking across our active service areas.
                </p>
                <div class="flex flex-col gap-3 mt-6">
                    <a
                        href="mailto:support@homecleaningco.com"
                        class="inline-flex items-center gap-3 text-white/80 hover:text-white transition-colors"
                    >
                        <Mail className="w-4 h-4 text-primary" />
                        support@homecleaningco.com
                    </a>
                    <a
                        href="tel:9543933479"
                        class="inline-flex items-center gap-3 text-white/80 hover:text-white transition-colors"
                    >
                        <Phone className="w-4 h-4 text-primary" />
                        (954) 393-3479
                    </a>
                </div>
            </div>

            <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/45 mb-4">
                    Service Areas
                </p>
                <div class="grid gap-2">
                    {
                        LOCATION_CONTENT.map((location) => (
                            <a
                                href={`/locations/${location.slug}`}
                                class="text-white/75 hover:text-white transition-colors"
                            >
                                {location.name}
                            </a>
                        ))
                    }
                </div>
            </div>

            <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/45 mb-4">
                    Services
                </p>
                <div class="grid gap-2">
                    {
                        SERVICE_CONTENT.map((service) => (
                            <a
                                href={`/services/${service.slug}`}
                                class="text-white/75 hover:text-white transition-colors"
                            >
                                {service.name}
                            </a>
                        ))
                    }
                </div>
            </div>

            <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-white/45 mb-4">
                    Support
                </p>
                <div class="grid gap-2">
                    {
                        supportLinks.map((link) => (
                            <a href={link.href} class="text-white/75 hover:text-white transition-colors">
                                {link.label}
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row items-center justify-between gap-6">
            <p class="text-white/40 text-sm font-medium">
                © {currentYear} Home Cleaning & Co. All rights reserved.
            </p>

            <div class="flex items-center gap-4">
                <a
                    href="#"
                    aria-label="Follow us on LinkedIn"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/60 hover:bg-primary hover:text-white transition-all duration-300"
                >
                    <Linkedin className="w-5 h-5" />
                </a>
                <a
                    href="#"
                    aria-label="Follow us on Facebook"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/60 hover:bg-primary hover:text-white transition-all duration-300"
                >
                    <Facebook className="w-5 h-5" />
                </a>
                <a
                    href="#"
                    aria-label="Follow us on Instagram"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white/60 hover:bg-primary hover:text-white transition-all duration-300"
                >
                    <Instagram className="w-5 h-5" />
                </a>
            </div>
        </div>
    </div>
</footer>
