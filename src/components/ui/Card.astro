---
interface Props {
    class?: string;
    [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div
    class:list={[
        "bg-white rounded-xl shadow-md p-6 hover:shadow-lg transition-shadow duration-300 border border-black/5",
        className,
    ]}
    {...rest}
>
    <slot />
</div>
