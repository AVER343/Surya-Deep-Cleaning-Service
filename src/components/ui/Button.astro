---
interface Props {
    variant?: "primary" | "secondary" | "outline" | "ghost";
    size?: "sm" | "md" | "lg";
    href?: string;
    type?: "button" | "submit" | "reset";
    class?: string;
    [key: string]: any;
}

const {
    variant = "primary",
    size = "md",
    href,
    type = "button",
    class: className,
    ...rest
} = Astro.props;

// Primary: Mint Green background, Dark Text
// Secondary: Steel Blue background, White Text (or dark if needed)
// Outline: Border Primary, Primary Text
// Ghost: Transparent, Dark Text

const variants = {
    primary:
        "bg-primary text-text shadow-sm hover:bg-primary/90 hover:-translate-y-0.5 transition-all duration-200",
    secondary:
        "bg-secondary text-white shadow-sm hover:bg-secondary/90 hover:-translate-y-0.5 transition-all duration-200",
    outline:
        "border-2 border-primary text-text hover:bg-primary/10 transition-colors duration-200",
    ghost: "text-text/70 hover:text-text hover:bg-black/5 transition-colors duration-200",
};

const sizes = {
    sm: "px-4 py-2 text-sm",
    md: "px-6 py-3 text-base",
    lg: "px-8 py-4 text-lg font-semibold",
};

const baseClass =
    "inline-flex items-center justify-center rounded-xl font-medium focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary disabled:opacity-50 disabled:pointer-events-none cursor-pointer";
const classes = [baseClass, variants[variant], sizes[size], className].join(
    " ",
);

const Tag = href ? "a" : "button";
---

<Tag href={href} type={!href ? type : undefined} class={classes} {...rest}>
    <slot />
</Tag>
