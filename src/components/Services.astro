---
import Section from "./ui/Section.astro";
import { Star, ArrowRight } from "lucide-react";
import { SERVICE_CONTENT } from "../content/services";

const services = SERVICE_CONTENT;
const allServices = [...services, ...services];
---

<Section id="services" class="bg-background-mint overflow-hidden py-16 md:py-24" fullWidth>
    <div class="text-center max-w-2xl mx-auto mb-16 px-4 animate-fade-in-up">
        <span
            class="inline-flex items-center gap-1.5 text-text-600 font-semibold tracking-wider uppercase text-xs bg-white border border-border-light px-4 py-1.5 rounded-full mb-4"
            >Featured Services</span
        >
        <h2
            class="text-4xl md:text-5xl font-bold text-secondary mb-6 font-sans tracking-tight"
        >
            Our Services
        </h2>
        <p class="text-text-600 text-lg">
            Explore our most requested cleaning options, then view the full
            services catalog for details and pricing context.
        </p>
    </div>

    <!-- Mobile/Tablet Layout: Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-8 px-4 lg:hidden">
        {
            services.map((service, index) => (
                <a
                    href={`/services/${service.slug}`}
                    class="flex flex-col items-center group/card"
                    style={`animation: fade-in-up 0.6s ease-out forwards ${index * 100}ms; opacity: 0;`}
                >
                    <!-- Image Card -->
                    <div class="w-full aspect-[3/4] rounded-2xl overflow-hidden shadow-md relative transition-all duration-300 group-hover/card:-translate-y-1 group-hover/card:shadow-xl">
                        <img
                            src={service.image}
                            alt={service.name}
                            class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-[1.02]"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent" />
                        {service.badge && (
                            <span class="absolute top-3 right-3 inline-flex items-center gap-1.5 bg-primary text-white text-[10px] font-bold uppercase tracking-[0.18em] px-2.5 py-1 rounded-full shadow-lg">
                                <Star className="w-3 h-3 fill-current" />
                                {service.badge}
                            </span>
                        )}
                    </div>

                    <!-- Title Below -->
                    <h3 class="mt-4 text-lg font-bold text-secondary text-center tracking-tight leading-tight">
                        {service.name}
                    </h3>
                    <p class="mt-2 text-xs text-text-600 text-center leading-relaxed max-w-[16rem]">
                        {service.shortDescription}
                    </p>
                    <span class="mt-3 text-sm font-semibold text-primary">Learn More</span>
                </a>
            ))
        }
    </div>

    <!-- Desktop Layout: Infinite Marquee -->
    <div class="hidden lg:block relative w-full overflow-hidden group">

        <!-- Scrolling Track -->
        <div
            class="flex w-max animate-scroll py-4"
        >
            {
                allServices.map((service) => (
                    <div class="flex-none px-3">
                        <a
                            href={`/services/${service.slug}`}
                            class="w-[15vw] flex flex-col group/card"
                        >
                            <div class="w-full aspect-[3/5] rounded-[2rem] overflow-hidden shadow-lg relative transition-all duration-300 group-hover/card:-translate-y-1 group-hover/card:shadow-2xl">
                                <img
                                    src={service.image}
                                    alt={service.name}
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover/card:scale-[1.04]"
                                />
                                {service.badge && (
                                    <span class="absolute top-4 left-4 z-20 inline-flex items-center gap-1.5 bg-primary text-white text-xs font-bold uppercase tracking-[0.18em] px-3 py-1.5 rounded-full shadow-lg">
                                        <Star className="w-3.5 h-3.5 fill-current" />
                                        {service.badge}
                                    </span>
                                )}
                                {/* Default: gradient + name at bottom */}
                                <div class="absolute inset-0 bg-gradient-to-t from-secondary/80 via-secondary/20 to-transparent transition-opacity duration-300 group-hover/card:opacity-0" />
                                <div class="absolute left-5 right-5 bottom-5 z-10 transition-opacity duration-300 group-hover/card:opacity-0">
                                    <h3 class="text-base font-bold text-white tracking-tight leading-snug">
                                        {service.name}
                                    </h3>
                                </div>
                                {/* Hover: dark overlay with description + CTA */}
                                <div class="absolute inset-0 bg-secondary/80 opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-5">
                                    <p class="text-white/90 text-xs leading-relaxed mb-4 translate-y-3 group-hover/card:translate-y-0 transition-transform duration-300">
                                        {service.shortDescription}
                                    </p>
                                    <span class="inline-flex items-center gap-1.5 self-start bg-primary text-white font-bold text-xs px-4 py-2 rounded-full translate-y-3 group-hover/card:translate-y-0 transition-transform duration-300 delay-75">
                                        View Service
                                        <ArrowRight className="w-3.5 h-3.5" />
                                    </span>
                                </div>
                            </div>
                        </a>
                    </div>
                ))
            }
        </div>
    </div>

    <div class="text-center mt-12 px-4">
        <a
            href="/services"
            class="inline-flex items-center gap-2 bg-primary text-white font-bold px-8 py-3.5 rounded-full shadow-lg shadow-primary/30 hover:bg-primary-dark hover:-translate-y-0.5 transition-all duration-300"
        >
            View All Services
        </a>
    </div>
</Section>

<style>
    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }

    .animate-scroll {
        animation: scroll 50s linear infinite;
    }
    .group:hover .animate-scroll {
        animation-play-state: paused;
    }

    @media (max-width: 768px) {
        .animate-scroll {
            animation-duration: 30s;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .animate-scroll {
            animation: none;
        }
    }
</style>
