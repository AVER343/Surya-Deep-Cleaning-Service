---
import { ChevronDown, Phone } from "lucide-react";
import { SERVICE_CONTENT } from "../content/services";

type NavLink = {
    text: string;
    href: string;
    match: "exact" | "prefix";
};

const phoneHref = "tel:9625140784";
const ctaLink = { text: "Book Now", href: "/book" };
const normalizePathname = (pathname: string) =>
    pathname !== "/" && pathname.endsWith("/")
        ? pathname.slice(0, -1)
        : pathname;
const currentPath = normalizePathname(Astro.url.pathname);
const isBookPage = currentPath === "/book";
const isServicesPage =
    currentPath === "/services" || currentPath.startsWith("/services/");

const links: NavLink[] = [
    { text: "Home", href: "/", match: "exact" },
    { text: "Pricing", href: "/pricing", match: "exact" },
    { text: "Locations", href: "/locations", match: "prefix" },
    { text: "Contact", href: "/contact", match: "exact" },
];

const isActive = (link: NavLink) =>
    link.match === "prefix"
        ? currentPath === link.href || currentPath.startsWith(`${link.href}/`)
        : currentPath === link.href;
---

<header
    id="main-header"
    class="fixed top-0 md:top-6 left-0 right-0 z-50 flex justify-center px-0 md:px-4 pointer-events-none transition-transform duration-300 transform translate-y-0"
>
    <div
        class="pointer-events-auto bg-white md:bg-white/95 md:backdrop-blur-xl md:border md:border-secondary/5 md:shadow-2xl md:rounded-full px-4 md:px-6 py-2 flex items-center justify-between gap-2 lg:gap-6 max-w-6xl w-full md:w-auto transition-all duration-500"
    >
        <a href="/" class="flex items-center gap-2 order-1 shrink-0">
            <img
                src="/images/logo.png"
                alt="Surya Deep Cleaning Service"
                class="h-9 md:h-10 w-auto object-contain"
            />
        </a>

        <nav class="hidden md:flex items-center gap-2 order-2">
            <a
                href="/"
                aria-current={currentPath === "/" ? "page" : undefined}
                class={`px-2 lg:px-4 py-2 text-xs lg:text-sm rounded-full transition-all whitespace-nowrap ${
                    currentPath === "/"
                        ? "text-primary bg-primary/10 font-semibold"
                        : "font-medium text-text-light hover:text-secondary hover:bg-black/5"
                }`}
            >
                Home
            </a>

            <div class="relative group/services">
                <a
                    href="/services"
                    aria-current={isServicesPage ? "page" : undefined}
                    class={`inline-flex items-center gap-1 px-2 lg:px-4 py-2 text-xs lg:text-sm rounded-full transition-all whitespace-nowrap ${
                        isServicesPage
                            ? "text-primary bg-primary/10 font-semibold"
                            : "font-medium text-text-light hover:text-secondary hover:bg-black/5"
                    }`}
                >
                    Services
                    <ChevronDown className="w-3.5 h-3.5" />
                </a>
                <div
                    class="absolute left-1/2 top-full pt-3 -translate-x-1/2 opacity-0 invisible translate-y-2 group-hover/services:opacity-100 group-hover/services:visible group-hover/services:translate-y-0 transition-all duration-200"
                >
                    <div
                        class="w-72 rounded-3xl border border-border-light bg-white shadow-2xl p-3"
                    >
                        <a
                            href="/services"
                            class="block rounded-2xl px-4 py-3 text-sm font-semibold text-secondary hover:bg-background-mint"
                        >
                            Browse all services
                        </a>
                        <div class="h-px bg-border-light my-2"></div>
                        {
                            SERVICE_CONTENT.map((service) => (
                                <a
                                    href={`/services/${service.slug}`}
                                    class="block rounded-2xl px-4 py-3 hover:bg-background-mint transition-colors"
                                >
                                    <p class="text-sm font-semibold text-secondary">
                                        {service.name}
                                    </p>
                                    <p class="text-xs text-text-500 mt-1">
                                        {service.hero.eyebrow}
                                    </p>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </div>

            {
                links.slice(1).map((link) => (
                    <a
                        href={link.href}
                        aria-current={isActive(link) ? "page" : undefined}
                        class={`px-2 lg:px-4 py-2 text-xs lg:text-sm rounded-full transition-all whitespace-nowrap ${
                            isActive(link)
                                ? "text-primary bg-primary/10 font-semibold"
                                : "font-medium text-text-light hover:text-secondary hover:bg-black/5"
                        }`}
                    >
                        {link.text}
                    </a>
                ))
            }
        </nav>

        <div class="hidden md:flex items-center gap-2 lg:gap-4 order-3 pl-2">
            <a
                href={phoneHref}
                class="flex items-center gap-2 text-text-light hover:text-primary font-medium transition-colors whitespace-nowrap"
            >
                <Phone className="w-4 h-4" />
                <span class="hidden lg:inline">+91 96251 40784</span>
            </a>
        </div>

        <button
            id="menu-btn"
            class="md:hidden p-2 rounded-full transition-colors order-3 hamburger-btn"
            aria-label="Toggle menu"
        >
            <div class="hamburger-icon">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </button>
    </div>

    <div
        id="mobile-menu"
        class="absolute top-full left-0 right-0 mt-0 md:hidden invisible opacity-0 -translate-y-2 transition-all duration-300 ease-in-out z-40 pointer-events-auto"
    >
        <div
            class="bg-white shadow-lg border-t border-border py-4 px-5 flex flex-col gap-1"
        >
            <a
                href="/"
                aria-current={currentPath === "/" ? "page" : undefined}
                class={`text-base py-3 px-2 border-b border-border transition-all mobile-link text-center ${
                    currentPath === "/"
                        ? "font-bold text-primary bg-primary/5 rounded-xl"
                        : "font-medium text-secondary/80 hover:text-primary"
                }`}
            >
                Home
            </a>

            <details
                class="border-b border-border rounded-xl group/mobile-services"
            >
                <summary
                    class={`list-none flex items-center justify-center gap-2 text-base py-3 px-2 cursor-pointer transition-all ${
                        isServicesPage
                            ? "font-bold text-primary bg-primary/5 rounded-xl"
                            : "font-medium text-secondary/80 hover:text-primary"
                    }`}
                >
                    Services
                    <ChevronDown
                        className="w-4 h-4 transition-transform group-open/mobile-services:rotate-180"
                    />
                </summary>
                <div class="pb-3 px-2">
                    <a
                        href="/services"
                        class="mobile-link block rounded-xl bg-background-mint px-4 py-3 text-sm font-semibold text-secondary mb-2 text-center"
                    >
                        Browse all services
                    </a>
                    <div class="grid gap-2">
                        {
                            SERVICE_CONTENT.map((service) => (
                                <a
                                    href={`/services/${service.slug}`}
                                    class="mobile-link block rounded-xl border border-border-light px-4 py-3 text-sm text-secondary text-center hover:border-primary/30 hover:text-primary transition-colors"
                                >
                                    {service.name}
                                </a>
                            ))
                        }
                    </div>
                </div>
            </details>

            {
                links.slice(1).map((link) => (
                    <a
                        href={link.href}
                        aria-current={isActive(link) ? "page" : undefined}
                        class={`text-base py-3 px-2 border-b border-border transition-all mobile-link text-center ${
                            isActive(link)
                                ? "font-bold text-primary bg-primary/5 rounded-xl"
                                : "font-medium text-secondary/80 hover:text-primary"
                        }`}
                    >
                        {link.text}
                    </a>
                ))
            }
            <a
                href={phoneHref}
                class="text-base font-medium text-secondary/80 hover:text-primary py-3 px-2 border-b border-border transition-all mobile-link text-center flex items-center justify-center gap-2"
            >
                <Phone className="w-4 h-4" />
                +91 96251 40784
            </a>
        </div>
    </div>
</header>

<script>
    document.addEventListener("astro:page-load", () => {
        const menuBtn = document.getElementById("menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const mobileLinks = document.querySelectorAll(".mobile-link");
        let isMenuOpen = false;

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;
            menuBtn?.classList.toggle("open", isMenuOpen);
            if (isMenuOpen) {
                mobileMenu?.classList.remove(
                    "invisible",
                    "opacity-0",
                    "-translate-y-2",
                );
            } else {
                mobileMenu?.classList.add(
                    "invisible",
                    "opacity-0",
                    "-translate-y-2",
                );
            }
        }

        menuBtn?.addEventListener("click", toggleMenu);

        mobileLinks.forEach((link) => {
            link.addEventListener("click", () => {
                if (isMenuOpen) toggleMenu();
            });
        });

        document.addEventListener("click", (e) => {
            if (
                isMenuOpen &&
                mobileMenu &&
                !mobileMenu.contains(e.target as Node) &&
                !menuBtn?.contains(e.target as Node)
            ) {
                toggleMenu();
            }
        });
    });
</script>

<style>
    .hamburger-icon {
        width: 22px;
        height: 16px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        cursor: pointer;
    }

    .hamburger-icon span {
        display: block;
        width: 100%;
        height: 2px;
        background-color: #1a1a2e;
        border-radius: 2px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform-origin: center;
    }

    .hamburger-btn.open .hamburger-icon span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .hamburger-btn.open .hamburger-icon span:nth-child(2) {
        opacity: 0;
        transform: scaleX(0);
    }

    .hamburger-btn.open .hamburger-icon span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }
</style>
