---
import Section from "./ui/Section.astro";
import { ChevronDown } from "lucide-react";
import { GLOBAL_FAQS } from "../content/faqs";
import { HOMEPAGE_TEASERS } from "../content/homepage";

interface Props {
    variant?: "home" | "full";
    showHeader?: boolean;
}

const { variant = "home", showHeader = true } = Astro.props as Props;
const isHome = variant === "home";
const faqs = isHome ? GLOBAL_FAQS.slice(0, 4) : GLOBAL_FAQS;
const sectionClass = showHeader
    ? "bg-surface py-16 md:py-24"
    : "bg-surface pt-4 pb-16 md:pt-8 md:pb-20";
---

<Section id="faq" class={sectionClass}>
    <div class="max-w-3xl mx-auto px-4">
        {showHeader && (
            <div class="text-center mb-16">
                <span
                    class="inline-flex items-center gap-1.5 text-text-600 font-semibold tracking-wider uppercase text-xs bg-white border border-border-light px-4 py-1.5 rounded-full mb-4"
                    >Common Questions</span
                >
                <h2
                    class="text-4xl md:text-5xl font-bold text-secondary mb-6 font-sans tracking-tight"
                >
                    Frequently Asked <span class="text-primary">Questions</span>
                </h2>
                <p class="text-text-600 text-lg">
                    {
                        isHome
                            ? HOMEPAGE_TEASERS.faq.description
                            : "Quick answers to common questions."
                    }
                </p>
            </div>
        )}

        <div class="space-y-4">
            {
                faqs.map((faq, index) => (
                    <div class="bg-white rounded-2xl shadow-md border border-border overflow-hidden transition-all duration-300 hover:shadow-lg group">
                        <details class="group w-full">
                            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
                                <h3 class="text-lg font-bold text-text-900 pr-8">
                                    {faq.question}
                                </h3>
                                <span class="text-primary transition-transform duration-300 group-open:rotate-180">
                                    <ChevronDown className="w-5 h-5" />
                                </span>
                            </summary>
                            <div class="px-6 pb-6 text-text-600 leading-relaxed">
                                {faq.answer}
                            </div>
                        </details>
                    </div>
                ))
            }
        </div>

        {isHome && (
            <div class="text-center mt-12">
                <a
                    href={HOMEPAGE_TEASERS.faq.href}
                    class="inline-flex items-center gap-2 bg-white text-secondary font-bold px-7 py-3 rounded-full border border-border-light hover:bg-background transition-colors"
                >
                    {HOMEPAGE_TEASERS.faq.cta}
                </a>
            </div>
        )}
    </div>
</Section>
